<%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-8 p-6 bg-white rounded-lg shadow-md">

    <h1 class="text-2xl font-bold text-center mb-6">
      Bookings on Your Homes
    </h1>

    <% if (bookings.length === 0) { %>
      <p class="text-center text-gray-500">No bookings yet</p>
    <% } %>

    <div class="space-y-4">
      <% bookings.forEach(b => { %>

        <div class="border p-4 rounded-lg shadow-sm flex justify-between items-center">

          <div>
            <h2 class="font-semibold text-lg">
              <%= b.home.houseName %>
            </h2>

            <p class="text-gray-600">
              Guest: <%= b.name %>
            </p>

            <p class="text-gray-600">
              Dates: 
              <%= new Date(b.fromDate).toDateString() %> 
              → 
              <%= new Date(b.toDate).toDateString() %>
            </p>
          </div>

          <!-- Cancel Button -->
          <form action="/host/cancel-booking/<%= b._id %>" method="POST">
            <button class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">
              Cancel
            </button>
          </form>

        </div>

      <% }) %>
    </div>

  </main>
</body>
</html>