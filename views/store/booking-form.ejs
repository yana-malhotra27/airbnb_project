<%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/nav') %>

  <main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md">

    <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">
      Book <%= home.houseName %>
    </h1>

    <!-- Hidden bookings data -->
    <div id="bookingsData" data-bookings='<%- JSON.stringify(bookings || []) %>' required></div>
    <div id="priceData" data-price="<%= pricePerNight %>" required></div>

    <form action="/bookings" method="POST" class="max-w-md mx-auto">

      <input type="hidden" name="homeId" value="<%= home._id %>" />

      <!-- Date Picker -->
      <input type="text" required id="datePicker" placeholder="Select booking dates" class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500" />

      <input type="hidden" name="fromDate" id="fromDate">
      <input type="hidden" name="toDate" id="toDate">


      <!-- Name -->
      <input type="text" name="name" placeholder="Enter your name" required class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500" />

      <!-- Aadhaar -->
      <input type="text" name="aadhaar" maxlength="4" placeholder="Aadhaar last 4 digits" required class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500" />

<div class="bg-gray-50 border rounded-lg p-4 mb-4 shadow-sm">

  <!-- Price per night -->
  <div class="flex justify-between text-gray-700 mb-2">
    <span>Price per night</span>
    <span>₹<%= pricePerNight %></span>
  </div>

  <!-- Nights -->
  <div class="flex justify-between text-gray-700 mb-2">
    <span>Nights</span>
    <span id="nights">0</span>
  </div>

  <hr class="my-2">

  <!-- Total -->
  <div class="flex justify-between text-lg font-semibold text-green-600">
    <span>Total</span>
    <span id="totalPrice">₹0</span>
  </div>

</div>

      <!-- Payment button -->
      <button type="button" class="w-full bg-blue-400 text-white py-2 rounded-md mb-4 hover:bg-blue-500 transition">
        Proceed to Payment
      </button>

      <!-- Submit -->
      <input type="submit" value="Confirm Booking" class="w-full bg-red-500 text-white py-2 rounded-md hover:bg-red-600 transition duration-300" />

    </form>

  </main>

  <!-- Flatpickr -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

  <script>
    const priceElement = document.getElementById("priceData");
    const pricePerNight = Number(priceElement.dataset.price);

    const bookingsDataElement = document.getElementById("bookingsData");
    const rawBookings = JSON.parse(bookingsDataElement.dataset.bookings);

    
    const disabledRanges = rawBookings.map(b => ({
      from: b.fromDate,
      to: b.toDate
    }));

    flatpickr("#datePicker", {
      mode: "range",
      minDate: "today",
      disable: disabledRanges,
      dateFormat: "Y-m-d",

      onChange: function(selectedDates) {
        if (selectedDates.length === 2) {
          const from = selectedDates[0];
          const to = selectedDates[1];

          document.getElementById("fromDate").value = from.toISOString();
          document.getElementById("toDate").value = to.toISOString();

          // Nights calculation
          const diffTime = to - from;
          const nights = Math.max(1, Math.ceil(diffTime / (1000 * 60 * 60 * 24)));

          // Total price
          const total = nights * pricePerNight;

          // Update UI
          document.getElementById("nights").innerText = "Nights: " + nights;
          document.getElementById("totalPrice").innerText = "Total Price: ₹" + total;
        }
      },

      onDayCreate: function(dObj, dStr, fp, dayElem) {
        const date = dayElem.dateObj;

        rawBookings.forEach(b => {
          const from = new Date(b.fromDate);
          const to = new Date(b.toDate);

          if (date >= from && date <= to) {
            dayElem.title = "Already Booked";
            dayElem.style.backgroundColor = "#fecaca";
            dayElem.style.color = "#991b1b";
          }
        });
      }
    });
  </script>

</body>

</html>