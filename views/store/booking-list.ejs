<%- include('../partials/head') %>
</head>

<body>
  <%- include('../partials/nav') %>

  <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-6xl">
    
    <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
      Here are your bookings:
    </h2>

    <div class="flex flex-wrap justify-center gap-6">

      <% bookings.forEach(b => { %>
        
        <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition duration-300 w-full max-w-sm">
          
          <!-- Image -->
          <img src="<%= b.home.photo %>" 
               alt="<%= b.home.houseName %>" 
               class="w-full h-48 object-cover">

          <div class="p-4">
            
            <!-- Title -->
            <h3 class="text-xl font-semibold text-gray-800 mb-2">
              <%= b.home.houseName %>
            </h3>

            <!-- Location -->
            <p class="text-gray-600 mb-2">
              📍 <%= b.home.location %>
            </p>

            <!-- Price + Rating -->
            <div class="flex justify-between items-center mb-2">
              <span class="text-lg font-bold text-red-500">
                Rs<%= b.home.price %> / night
              </span>

              <div class="flex items-center">
                ⭐ <span class="text-gray-700 ml-1"><%= b.home.rating %></span>
              </div>
            </div>

            <!-- Booking Dates -->
            <p class="text-gray-700 text-sm mb-1">
              <strong>From:</strong> <%= b.fromDate.toDateString() %>
            </p>

            <p class="text-gray-700 text-sm mb-1">
              <strong>To:</strong> <%= b.toDate.toDateString() %>
            </p>

            <!-- Name -->
            <p class="text-gray-700 text-sm mb-3">
              <strong>Name:</strong> <%= b.name %>
            </p>

            <!-- Cancel Button -->
            <form action="/bookings/delete/<%= b._id %>" method="POST">
              <button class="bg-red-300 p-2 rounded hover:bg-red-500">
                Cancel Booking
              </button>
            </form>

          </div>
        </div>

      <% }) %>

    </div>
  </main>

</body>
</html>